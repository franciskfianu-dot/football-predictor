# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/football_predictor

# Redis (Upstash in production)
REDIS_URL=redis://localhost:6379/0

# OpenWeatherMap - free at https://openweathermap.org/api
# Register and copy your API key here
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Admin endpoint protection
ADMIN_SECRET_TOKEN=change_this_to_a_long_random_string_in_production

# MLflow tracking
MLFLOW_TRACKING_URI=http://localhost:5001

# Environment
ENVIRONMENT=development

# Scraper settings (seconds between requests - be polite)
SCRAPE_DELAY_SECONDS=3
SCRAPE_RETRY_COUNT=3

# CORS - frontend URL
CORS_ORIGINS=http://localhost:5173

# Google Sheets (filled in via in-app setup wizard)
# Paste your full service account JSON as a single line here
GOOGLE_SERVICE_ACCOUNT_JSON={}

# Model storage path
MODEL_STORAGE_PATH=./model_storage

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
